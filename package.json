{
  "name": "alfred-open-with-vscode",
  "type": "module",
  "version": "1.0.0",
  "packageManager": "pnpm@10.32.0",
  "description": "💻 An Alfred workflow for opening folders with Visual Studio Code",
  "author": {
    "name": "Frankie",
    "email": "1426203851@qq.com",
    "url": "https://github.com/toFrankie"
  },
  "license": "MIT",
  "homepage": "https://github.com/toFrankie/alfred-open-with-vscode",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/tofrankie/alfred-open-with-vscode.git"
  },
  "bugs": {
    "url": "https://github.com/toFrankie/alfred-open-with-vscode/issues"
  },
  "keywords": [
    "alfred",
    "workflow",
    "open",
    "vscode",
    "Visual Studio Code"
  ],
  "bin": {
    "alfred-open-with-vscode-import": "bin/install.sh"
  },
  "files": [
    "CHANGELOG.md",
    "alfred-open-with-vscode.alfredworkflow",
    "bin"
  ],
  "engines": {
    "node": ">=10.0.0"
  },
  "publishConfig": {
    "registry": "https://registry.npmjs.org/",
    "access": "public"
  },
  "scripts": {
    "build": "run-s build:js build:alfred",
    "build:js": "rollup -c",
    "build:alfred": "node scripts/build.js",
    "prepublish": "run-s lint build",
    "lint": "run-s eslint:fix prettier:fix",
    "eslint:fix": "eslint . --fix --cache",
    "prettier:fix": "prettier . --write --cache '!pnpm-lock.yaml'"
  },
  "dependencies": {
    "fuzzball": "^2.2.3"
  },
  "devDependencies": {
    "@babel/core": "^7.29.0",
    "@babel/plugin-transform-runtime": "^7.29.0",
    "@babel/preset-env": "^7.29.2",
    "@rollup/plugin-babel": "^7.0.0",
    "@rollup/plugin-json": "^6.1.0",
    "@rollup/plugin-node-resolve": "^16.0.3",
    "@tofrankie/eslint": "^0.2.1",
    "@tofrankie/prettier": "^0.2.0",
    "adm-zip": "^0.5.17",
    "eslint": "^10.2.0",
    "npm-run-all2": "^8.0.4",
    "prettier": "^3.8.2",
    "rollup": "^4.60.1"
  }
}
